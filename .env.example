# Ivette HPC (PBS/SSH) credentials & config.
# Copy this file to  .env  (which is gitignored) and fill in your values.
#
# PREFERRED: set up an SSH key once ( ssh-keygen ; ssh-copy-id user@fe1.scl.kyoto-u.ac.jp )
# and leave IVETTE_HPC_PASSWORD unset — key auth is more secure and needs no extra tools.

IVETTE_HPC_USER=your_username
IVETTE_HPC_HOST=fe1.scl.kyoto-u.ac.jp
IVETTE_HPC_MODULE=g16/c01
IVETTE_HPC_REMOTE_ROOT=ivette_runs
IVETTE_HPC_QUEUE=auto
# IVETTE_HPC_WALLTIME_HOURS=0        # 0 = queue default (SMALL caps at 12 h)
# IVETTE_HPC_POLL_SECONDS=30

# OPTIONAL password auth. Requires the 'sshpass' tool installed locally.
# Less secure than an SSH key even though .env is gitignored — prefer keys.
# IVETTE_HPC_PASSWORD=your_password
